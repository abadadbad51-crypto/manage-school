rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, name, email, role (admin, teacher, student, parent), studentId, classId, createdAt
    //
    // Collection: classes
    // Fields: name, grade, section, teacherId
    //
    // Collection: subjects
    // Fields: name, code
    //
    // Collection: attendance
    // Fields: studentId, classId, date, status
    //
    // Collection: grades
    // Fields: studentId, subjectId, score, term, date
    //
    // Collection: fees
    // Fields: studentId, amount, status, dueDate, paidDate
    //
    // Collection: notifications
    // Fields: recipientId, title, message, date, read
    //
    // Collection: teacherAvailability
    // Fields: teacherId, availability (array of {day, slot, type}), updatedAt
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "abadadbad51@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isTeacher() {
      return isAuthenticated() && getUserData().role == 'teacher';
    }

    function isStudent() {
      return isAuthenticated() && getUserData().role == 'student';
    }

    function isParent() {
      return isAuthenticated() && getUserData().role == 'parent';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.uid is string && data.name is string && data.email is string &&
             data.role in ['admin', 'teacher', 'student', 'parent'] &&
             data.name.size() > 0 && data.name.size() < 100;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data);
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
    }

    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /subjects/{subjectId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    match /grades/{gradeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    match /fees/{feeId} {
      allow read: if isAdmin() || (isAuthenticated() && (isOwner(resource.data.studentId) || isParent()));
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.recipientId || isAdmin());
      allow create: if isAdmin() || isTeacher();
      allow update: if isAuthenticated() && request.auth.uid == resource.data.recipientId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    match /schedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    match /resources/{resourceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderId;
    }

    match /teacherAvailability/{teacherId} {
      allow read: if isAuthenticated() && (request.auth.uid == teacherId || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == teacherId || isAdmin());
    }
  }
}
